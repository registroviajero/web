---
import Layout from '../../layouts/Layout.astro'
import Landing from '../../components/Landing.astro'
import { LANDING } from '../../i18n/content'

const locale = 'en' as const
const meta = LANDING[locale].meta
---

<Layout title={meta.title} description={meta.description} locale={locale} logicalPath="/">
  <Landing locale={locale} />
</Layout>
