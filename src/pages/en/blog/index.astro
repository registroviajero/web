---
import Layout from '../../../layouts/Layout.astro'
import Nav from '../../../components/Nav.astro'
import Footer from '../../../components/Footer.astro'
import LocaleBanner from '../../../components/LocaleBanner.astro'
import { UI } from '../../../i18n/ui'
import { formatDate, localizedPath } from '../../../i18n/utils'
import { getPostsByLocale, getSlug } from '../../../i18n/blog'

const locale = 'en' as const
const t = UI[locale].blog

const posts = await getPostsByLocale(locale)
const blogPath = localizedPath(locale, '/blog')
---

<Layout title={t.listTitleMeta} description={t.listDescriptionMeta} locale={locale} logicalPath="/blog">
  <Nav locale={locale} />
  <LocaleBanner locale={locale} />

  <main class="pt-28 pb-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900">{t.indexHeading}</h1>
      <p class="mt-3 text-lg text-gray-600">{t.indexIntro}</p>

      <div class="mt-12 space-y-8">
        {posts.map((post) => (
          <article class="group">
            <a href={`${blogPath}${getSlug(post)}/`} class="flex flex-col sm:flex-row gap-4 sm:gap-6 items-start">
              {post.data.cover && (
                <img
                  src={post.data.cover}
                  alt={post.data.coverAlt ?? post.data.title}
                  width="1000"
                  height="630"
                  loading="lazy"
                  class="w-full aspect-square sm:w-56 sm:h-56 sm:aspect-auto object-cover rounded-xl sm:flex-shrink-0"
                />
              )}
              <div class="flex-1 min-w-0">
                <time datetime={post.data.date.toISOString().split('T')[0]} class="text-sm text-gray-500">
                  {formatDate(locale, post.data.date)}
                </time>
                <h2 class="mt-2 text-xl sm:text-2xl font-bold text-gray-900 group-hover:text-primary-600 transition-colors duration-150">
                  {post.data.title}
                </h2>
                <p class="mt-2 text-gray-600 leading-relaxed">{post.data.description}</p>
                <span class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-primary-600">
                  {t.readMore}
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
                </span>
              </div>
            </a>
          </article>
        ))}
      </div>

      {posts.length === 0 && (
        <p class="mt-12 text-gray-500 text-center">{t.empty}</p>
      )}
    </div>
  </main>

  <Footer locale={locale} />
</Layout>
