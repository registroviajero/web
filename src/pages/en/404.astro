---
import Layout from '../../layouts/Layout.astro'
import Nav from '../../components/Nav.astro'
import Footer from '../../components/Footer.astro'
import { HELP_URL } from '../../i18n/config'
import { UI } from '../../i18n/ui'
import type { LocalePaths } from '../../i18n/utils'

const locale = 'en' as const
const t = UI[locale].notFound

// On a 404 the same URL doesn't exist in the other locale either, so the
// locale switch routes to that locale's home rather than to a phantom 404.
const localePaths: LocalePaths = { es: '/', en: '/en/' }
---

<Layout title={t.title} description={t.description} locale={locale} logicalPath="/404/" noindex>
  <Nav locale={locale} localePaths={localePaths} />

  <main id="main-content" class="pt-32 pb-20 min-h-[70vh] flex items-center">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-sm font-semibold text-primary-600 uppercase tracking-wide">{t.label}</p>
      <h1 class="mt-3 text-4xl sm:text-5xl font-bold tracking-tight text-gray-900">{t.heading}</h1>
      <p class="mt-6 text-lg text-gray-600">{t.body}</p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/en/" class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-white bg-primary-600 hover:bg-primary-700 rounded-lg transition-colors duration-150">
          {t.backHome}
        </a>
        <a href={HELP_URL} class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-gray-700 bg-white hover:bg-gray-50 border border-gray-300 rounded-lg transition-colors duration-150">
          {t.helpCenter}
        </a>
      </div>
      <div class="mt-12 pt-8 border-t border-gray-100">
        <p class="text-sm text-gray-500">{t.lookingForHeading}</p>
        <ul class="mt-4 flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm">
          {t.links.map((link) => (
            <li><a href={link.href} class="text-primary-600 hover:underline">{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>
  </main>

  <Footer locale={locale} />
</Layout>
