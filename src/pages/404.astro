---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'

const HELP_URL = 'https://help.registroviajero.com'
---

<Layout
  title="Página no encontrada — RegistroViajero"
  description="La página que buscas no existe o ha sido movida. Vuelve al inicio o consulta el Centro de Ayuda."
>
  <Nav />

  <main class="pt-32 pb-20 min-h-[70vh] flex items-center">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-sm font-semibold text-primary-600 uppercase tracking-wide">Error 404</p>
      <h1 class="mt-3 text-4xl sm:text-5xl font-bold tracking-tight text-gray-900">Página no encontrada</h1>
      <p class="mt-6 text-lg text-gray-600">
        La página que buscas no existe, se ha movido o ha sido eliminada. Revisa la dirección o vuelve al inicio.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-white bg-primary-600 hover:bg-primary-700 rounded-lg transition-colors duration-150">
          Volver al inicio
        </a>
        <a href={HELP_URL} class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-gray-700 bg-white hover:bg-gray-50 border border-gray-300 rounded-lg transition-colors duration-150">
          Centro de Ayuda
        </a>
      </div>
      <div class="mt-12 pt-8 border-t border-gray-100">
        <p class="text-sm text-gray-500">¿Buscabas algo en concreto?</p>
        <ul class="mt-4 flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm">
          <li><a href="/#funcionalidades" class="text-primary-600 hover:underline">Funcionalidades</a></li>
          <li><a href="/#precios" class="text-primary-600 hover:underline">Precios</a></li>
          <li><a href="/blog" class="text-primary-600 hover:underline">Blog</a></li>
          <li><a href="/legal/privacidad" class="text-primary-600 hover:underline">Privacidad</a></li>
          <li><a href="/legal/aviso-legal" class="text-primary-600 hover:underline">Aviso legal</a></li>
        </ul>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
