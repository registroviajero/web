---
import Layout from '../layouts/Layout.astro'

const APP_URL = 'https://app.registroviajero.com'
const HELP_URL = 'https://help.registroviajero.com'

const steps = [
  { num: '1', title: 'Registra tus alojamientos', desc: 'Configura cada propiedad con su dirección, tipo y código de establecimiento del Ministerio.' },
  { num: '2', title: 'Crea reservas', desc: 'Manualmente o importando automáticamente desde Booking.com, Airbnb, VRBO y más vía iCal.' },
  { num: '3', title: 'Envía el enlace de check-in', desc: 'Cada huésped recibe un enlace único. Sin app, sin registro, sin descargas.' },
  { num: '4', title: 'Revisa y valida', desc: 'Comprueba que los datos son correctos y marca la reserva como validada.' },
  { num: '5', title: 'Envía al Ministerio', desc: 'Con un clic, genera los XML, comprime y envía a SES.HOSPEDAJES automáticamente.' },
]

const features = [
  { title: 'Check-in digital', desc: 'Enlace único por huésped. Formulario adaptado a móvil en 9 idiomas. Subida de fotos del documento desde la cámara.', icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />' },
  { title: 'Importación iCal', desc: 'Sincroniza reservas cada 15 minutos desde Booking.com, Airbnb, VRBO, Expedia, Tripadvisor y Google Calendar.', icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />' },
  { title: 'Envío directo al Ministerio', desc: 'Genera automáticamente los XML (parte de viajeros + reserva de hospedaje), comprime y envía a SES.HOSPEDAJES.', icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />' },
  { title: 'Equipo y roles', desc: 'Propietario, administrador y miembro. Cada uno con su propio acceso y permisos.', icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />' },
  { title: 'Seguridad y RGPD', desc: 'Credenciales cifradas con AES-256. Retención automática de 3 años. Eliminación de cuenta con anonimización.', icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />' },
  { title: 'Panel de control', desc: 'Calendario de llegadas, estados de reserva, alertas de errores del Ministerio y actividad reciente.', icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" />' },
]

const faqs = [
  { q: '¿Mis huéspedes necesitan instalar algo?', a: 'No. Reciben un enlace que abren en su navegador. Sin app, sin registro, sin descargas.' },
  { q: '¿Funciona en Cataluña y País Vasco?', a: 'Todavía no. Estas comunidades usan sistemas propios (Mossos d\'Esquadra y Ertzaintza). La integración está en desarrollo.' },
  { q: '¿Qué pasa si caduca mi suscripción?', a: 'Los huéspedes siempre pueden completar sus datos. El check-in nunca se bloquea por el estado de tu plan.' },
  { q: '¿Puedo gestionar múltiples propiedades?', a: 'Sí. Desde una misma cuenta de agencia puedes gestionar todas tus propiedades, cada una con sus propias credenciales SES.' },
]
---

<Layout
  title="RegistroViajero — Automatiza partes de viajeros y comunicaciones al Ministerio"
  description="Software para cumplir con el RD 933/2021. Tus huéspedes se registran desde su móvil, tú validas y envías a SES.HOSPEDAJES con un clic. 15 días de prueba gratis."
>
  <!-- Nav -->
  <nav class="fixed top-0 w-full bg-white/80 backdrop-blur-md border-b border-gray-100 z-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2">
        <img src="/logo.svg" alt="RegistroViajero" class="h-8" />
      </a>
      <div class="hidden sm:flex items-center gap-6 text-sm font-medium text-gray-600">
        <a href="#funcionalidades" class="hover:text-gray-900 transition-colors">Funcionalidades</a>
        <a href="#como-funciona" class="hover:text-gray-900 transition-colors">Cómo funciona</a>
        <a href="#precios" class="hover:text-gray-900 transition-colors">Precios</a>
        <a href="/blog" class="hover:text-gray-900 transition-colors">Blog</a>
        <a href={HELP_URL} class="hover:text-gray-900 transition-colors">Ayuda</a>
      </div>
      <div class="flex items-center gap-3">
        <a href={`${APP_URL}/login`} class="hidden sm:inline-flex text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors">Iniciar sesión</a>
        <a href={`${APP_URL}/register`} class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-primary-600 hover:bg-primary-700 rounded-lg transition-colors">
          Prueba gratis
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="pt-32 pb-20 sm:pt-40 sm:pb-28">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary-50 text-primary-700 text-sm font-medium mb-6">
          Real Decreto 933/2021
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-gray-900 leading-tight">
          Partes de viajeros<br />
          <span class="text-primary-600">automáticos</span>
        </h1>
        <p class="mt-6 text-lg sm:text-xl text-gray-600 leading-relaxed max-w-2xl">
          Tus huéspedes se registran desde su móvil. Tú validas y envías a SES.HOSPEDAJES con un clic. Sin papeles, sin errores, sin complicaciones.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a href={`${APP_URL}/register`} class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-white bg-primary-600 hover:bg-primary-700 rounded-lg transition-colors shadow-sm">
            Empieza gratis — 15 días
          </a>
          <a href="#como-funciona" class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-gray-700 bg-white hover:bg-gray-50 border border-gray-300 rounded-lg transition-colors">
            Cómo funciona
          </a>
        </div>
        <p class="mt-4 text-sm text-gray-500">Sin tarjeta de crédito. Acceso ilimitado durante la prueba.</p>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="funcionalidades" class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Todo lo que necesitas para cumplir</h2>
        <p class="mt-4 text-lg text-gray-600">
          Desde la recogida de datos hasta el envío al Ministerio, todo integrado en una sola plataforma.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {features.map((f) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <div class="w-10 h-10 rounded-lg bg-primary-50 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" set:html={f.icon} />
            </div>
            <h3 class="text-lg font-semibold text-gray-900">{f.title}</h3>
            <p class="mt-2 text-gray-600 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section id="como-funciona" class="py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Cómo funciona</h2>
        <p class="mt-4 text-lg text-gray-600">
          Cinco pasos para enviar los partes de viajeros al Ministerio.
        </p>
      </div>
      <div class="max-w-3xl mx-auto space-y-8">
        {steps.map((s) => (
          <div class="flex gap-6">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-primary-600 text-white flex items-center justify-center font-bold text-sm">
              {s.num}
            </div>
            <div>
              <h3 class="text-lg font-semibold text-gray-900">{s.title}</h3>
              <p class="mt-1 text-gray-600">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Platforms -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Importa reservas automáticamente</h2>
      <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
        Conecta tus calendarios iCal y las reservas se sincronizan cada 15 minutos.
      </p>
      <div class="mt-12 flex flex-wrap items-center justify-center gap-8 sm:gap-12 text-gray-400">
        {['Booking.com', 'Airbnb', 'VRBO', 'Expedia', 'Tripadvisor', 'Google Calendar'].map((p) => (
          <span class="text-lg font-semibold text-gray-500">{p}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section id="precios" class="py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Precio simple y transparente</h2>
        <p class="mt-4 text-lg text-gray-600">
          Empieza con 15 días de prueba gratuita. Después, un precio por alojamiento.
        </p>
      </div>
      <div class="max-w-lg mx-auto">
        <div class="bg-white rounded-2xl shadow-lg border border-gray-200 overflow-hidden">
          <div class="p-8">
            <h3 class="text-lg font-semibold text-gray-900">Plan Pro</h3>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-5xl font-bold text-gray-900">5 &euro;</span>
              <span class="text-gray-500">/alojamiento/mes</span>
            </div>
            <p class="mt-2 text-sm text-gray-500">Facturación mensual.</p>
            <a href={`${APP_URL}/register`} class="mt-8 block w-full text-center px-6 py-3 text-base font-medium text-white bg-primary-600 hover:bg-primary-700 rounded-lg transition-colors">
              Empieza gratis — 15 días
            </a>
            <p class="mt-3 text-center text-sm text-gray-500">Sin tarjeta de crédito</p>
          </div>
          <div class="border-t border-gray-100 px-8 py-6 bg-gray-50">
            <ul class="space-y-3 text-sm text-gray-600">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                Huéspedes ilimitados
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                Envío directo a SES.HOSPEDAJES
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                Importación iCal automática
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                Check-in digital en 9 idiomas
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                Equipo con roles y permisos
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                Exportación PDF y CSV
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                Códigos QR para check-in presencial
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                Registro de auditoría inmutable
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Security / Trust -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Seguridad y cumplimiento</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 text-center">
        <div class="bg-white rounded-xl p-6 border border-gray-100">
          <p class="text-2xl font-bold text-primary-600">AES-256</p>
          <p class="mt-2 text-sm text-gray-600">Credenciales cifradas</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-100">
          <p class="text-2xl font-bold text-primary-600">RGPD</p>
          <p class="mt-2 text-sm text-gray-600">Retención y eliminación automática</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-100">
          <p class="text-2xl font-bold text-primary-600">HTTPS</p>
          <p class="mt-2 text-sm text-gray-600">Comunicaciones cifradas</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-100">
          <p class="text-2xl font-bold text-primary-600">Multi-tenant</p>
          <p class="mt-2 text-sm text-gray-600">Datos aislados por agencia</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 text-center mb-12">Preguntas frecuentes</h2>
      <div class="space-y-6">
        {faqs.map((f) => (
          <details class="group bg-white border border-gray-200 rounded-xl">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer text-gray-900 font-medium">
              {f.q}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </summary>
            <div class="px-6 pb-4 text-gray-600">{f.a}</div>
          </details>
        ))}
      </div>
      <p class="mt-8 text-center text-gray-500">
        ¿Más preguntas? Consulta el <a href={HELP_URL} class="text-primary-600 hover:underline">Centro de Ayuda</a>.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-primary-600">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white">Empieza a enviar partes de viajeros hoy</h2>
      <p class="mt-4 text-lg text-primary-100">
        15 días de prueba gratis. Sin tarjeta de crédito. Listo en 2 minutos.
      </p>
      <a href={`${APP_URL}/register`} class="mt-8 inline-flex items-center px-8 py-3.5 text-base font-medium text-primary-600 bg-white hover:bg-primary-50 rounded-lg transition-colors shadow-sm">
        Crear cuenta gratis
      </a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-gray-900 text-gray-400 py-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <div>
          <img src="/logo.svg" alt="RegistroViajero" class="h-8 brightness-0 invert opacity-80" />
          <p class="mt-4 text-sm leading-relaxed">
            Software de registro de viajeros y partes de hospedaje para agencias de alojamiento turístico en España.
          </p>
        </div>
        <div>
          <h4 class="text-white font-semibold text-sm mb-4">Producto</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="#funcionalidades" class="hover:text-white transition-colors">Funcionalidades</a></li>
            <li><a href="#precios" class="hover:text-white transition-colors">Precios</a></li>
            <li><a href="/blog" class="hover:text-white transition-colors">Blog</a></li>
            <li><a href={HELP_URL} class="hover:text-white transition-colors">Centro de Ayuda</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-white font-semibold text-sm mb-4">Legal</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="/legal/aviso-legal" class="hover:text-white transition-colors">Aviso legal</a></li>
            <li><a href="/legal/privacidad" class="hover:text-white transition-colors">Privacidad</a></li>
            <li><a href="/legal/terminos" class="hover:text-white transition-colors">Términos de uso</a></li>
            <li><a href="/legal/cookies" class="hover:text-white transition-colors">Cookies</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-white font-semibold text-sm mb-4">Acceso</h4>
          <ul class="space-y-2 text-sm">
            <li><a href={`${APP_URL}/login`} class="hover:text-white transition-colors">Iniciar sesión</a></li>
            <li><a href={`${APP_URL}/register`} class="hover:text-white transition-colors">Crear cuenta</a></li>
          </ul>
        </div>
      </div>
      <div class="mt-12 pt-8 border-t border-gray-800 text-sm text-center">
        &copy; 2026 RegistroViajero. Cumplimiento del Real Decreto 933/2021.
      </div>
    </div>
  </footer>

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "RegistroViajero",
    "url": "https://registroviajero.com",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "description": "Software para cumplir con el Real Decreto 933/2021. Registro digital de viajeros, envío automático de partes de hospedaje a SES.HOSPEDAJES del Ministerio del Interior.",
    "offers": {
      "@type": "Offer",
      "price": "5",
      "priceCurrency": "EUR",
      "description": "Plan Pro — por alojamiento/mes",
      "eligibleQuantity": { "@type": "QuantitativeValue", "minValue": 2 }
    },
    "featureList": [
      "Check-in digital para huéspedes",
      "Envío automático a SES.HOSPEDAJES",
      "Importación iCal (Booking.com, Airbnb, VRBO)",
      "Exportación PDF y CSV",
      "Equipo con roles y permisos",
      "Registro de auditoría inmutable",
      "Cumplimiento RGPD"
    ]
  })} />
</Layout>
