---
import '../styles/global.css'

interface Props {
  title: string
  description: string
  canonical?: string
  type?: 'website' | 'article'
  publishedDate?: string
  modifiedDate?: string
}

const { title, description, canonical, type = 'website', publishedDate, modifiedDate } = Astro.props
const siteUrl = 'https://registroviajero.com'
const ogImage = `${siteUrl}/og-image.png`
const canonicalUrl = canonical || Astro.url.href

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'RegistroViajero',
  url: siteUrl,
  logo: `${siteUrl}/logo.svg`,
  description: 'Software SaaS para cumplir con el Real Decreto 933/2021. Check-in digital y envío automático de partes de viajeros a SES.HOSPEDAJES.',
  areaServed: {
    '@type': 'Country',
    name: 'España',
  },
  sameAs: [
    'https://app.registroviajero.com',
    'https://help.registroviajero.com',
  ],
}

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'RegistroViajero',
  url: siteUrl,
  inLanguage: 'es-ES',
  publisher: {
    '@type': 'Organization',
    name: 'RegistroViajero',
    url: siteUrl,
  },
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#2563eb" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="RegistroViajero" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {publishedDate && <meta property="article:published_time" content={publishedDate} />}
    {modifiedDate && <meta property="article:modified_time" content={modifiedDate} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="keywords" content="registro viajeros, parte de viajeros, reserva hospedaje, SES hospedajes, Real Decreto 933/2021, RD 933, alojamiento turístico, check-in online, software hospedaje, envío partes ministerio" />

    <link rel="alternate" type="application/rss+xml" title="Blog — RegistroViajero" href="/rss.xml" />

    <link rel="preconnect" href="https://analytics.registroviajero.com" crossorigin />
    <link rel="dns-prefetch" href="https://analytics.registroviajero.com" />

    <script defer src="https://analytics.registroviajero.com/script.js" data-website-id="6949d7b6-9448-414c-b72d-37d486b796e4"></script>

    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  </head>
  <body class="bg-white text-gray-900 antialiased">
    <slot />
  </body>
</html>
