---
import '../styles/global.css'

interface Props {
  title: string
  description: string
  canonical?: string
}

const { title, description, canonical } = Astro.props
const siteUrl = 'https://registroviajero.com'
const ogImage = `${siteUrl}/og-image.png`
const canonicalUrl = canonical || Astro.url.href
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="theme-color" content="#2563eb" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="RegistroViajero" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="keywords" content="registro viajeros, parte de viajeros, reserva hospedaje, SES hospedajes, Real Decreto 933/2021, RD 933, alojamiento turístico, check-in online, software hospedaje, envío partes ministerio" />

    <script defer src="https://analytics.registroviajero.com/script.js" data-website-id="6949d7b6-9448-414c-b72d-37d486b796e4"></script>
  </head>
  <body class="bg-white text-gray-900 antialiased">
    <slot />
  </body>
</html>
