---
import Layout from './Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
import LocaleBanner from '../components/LocaleBanner.astro'
import { type Locale } from '../i18n/config'
import { buildLocalePaths, getLocaleFromUrl, stripLocalePrefix, type LocalePaths } from '../i18n/utils'
import { UI, legalKeyFromSlug, legalLocalePaths } from '../i18n/ui'

interface Props {
  title?: string
  description?: string
  frontmatter?: {
    title: string
    description: string
    locale?: Locale
    translationKey?: string
    showReferenceDisclaimer?: boolean
  }
  locale?: Locale
}

const fm = Astro.props.frontmatter
const resolvedTitle = fm?.title || Astro.props.title || ''
const resolvedDescription = fm?.description || Astro.props.description || ''
const locale: Locale = Astro.props.locale ?? fm?.locale ?? getLocaleFromUrl(Astro.url)
const showDisclaimer = fm?.showReferenceDisclaimer ?? (locale === 'en')
const logicalPath = stripLocalePrefix(Astro.url.pathname)

// If this is a legal page, map the slug across locales so hreflang alternates
// point at the right localized slug (e.g. /legal/privacidad/ ↔ /en/legal/privacy/).
const legalMatch = logicalPath.match(/^\/legal\/([^/]+)\/?$/)
const legalKey = legalMatch ? legalKeyFromSlug(locale, legalMatch[1]) : undefined
const localePaths: LocalePaths = legalKey
  ? legalLocalePaths(legalKey)
  : buildLocalePaths(logicalPath)

const disclaimer = UI[locale].legalDisclaimer
---

<Layout
  title={`${resolvedTitle} — RegistroViajero`}
  description={resolvedDescription}
  locale={locale}
  logicalPath={logicalPath}
  localePaths={localePaths}
>
  <Nav locale={locale} localePaths={localePaths} />
  <LocaleBanner locale={locale} localePaths={localePaths} />

  <main id="main-content" class="pt-28 pb-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      {showDisclaimer && disclaimer.title && (
        <aside class="mb-8 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900" role="note" aria-label={disclaimer.title}>
          <strong class="font-semibold">{disclaimer.title}.</strong> {disclaimer.body}
        </aside>
      )}
      <article class="prose prose-gray max-w-none prose-headings:font-bold prose-a:text-primary-600 prose-a:no-underline prose-a:hover:underline">
        <slot />
      </article>
    </div>
  </main>

  <Footer locale={locale} />
</Layout>
