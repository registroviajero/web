---
import Layout from './Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'

interface Props {
  title: string
  description: string
  date: Date
  updated?: Date
  author: string
  readingTime?: number
  slug?: string
}

const { title, description, date, updated, author, readingTime, slug } = Astro.props

const SITE_URL = 'https://registroviajero.com'
const APP_URL = 'https://app.registroviajero.com'

const formattedDate = date.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})

const publishedIso = date.toISOString().split('T')[0]
const modifiedIso = (updated ?? date).toISOString().split('T')[0]

const postUrl = slug ? `${SITE_URL}/blog/${slug}` : Astro.url.href

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE_URL}/` },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE_URL}/blog` },
    { '@type': 'ListItem', position: 3, name: title, item: postUrl },
  ],
}
---

<Layout title={`${title} — Blog RegistroViajero`} description={description} type="article" publishedDate={publishedIso} modifiedDate={modifiedIso}>
  <Nav />

  <main class="pt-28 pb-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <nav aria-label="Breadcrumb" class="mb-6 text-sm">
        <ol class="flex flex-wrap items-center gap-2 text-gray-500">
          <li><a href="/" class="hover:text-primary-600">Inicio</a></li>
          <li aria-hidden="true">/</li>
          <li><a href="/blog" class="hover:text-primary-600">Blog</a></li>
          <li aria-hidden="true">/</li>
          <li class="text-gray-700 truncate max-w-[200px] sm:max-w-none">{title}</li>
        </ol>
      </nav>
      <a href="/blog" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-primary-600 transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
        Volver al blog
      </a>
      <header class="mb-10">
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 leading-tight">{title}</h1>
        <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-gray-500">
          <time datetime={publishedIso}>{formattedDate}</time>
          {updated && updated.valueOf() !== date.valueOf() && (
            <>
              <span aria-hidden="true">·</span>
              <span>Actualizado <time datetime={modifiedIso}>{updated.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}</time></span>
            </>
          )}
          <span aria-hidden="true">·</span>
          <span>{author}</span>
          {readingTime && (
            <>
              <span aria-hidden="true">·</span>
              <span>{readingTime} min de lectura</span>
            </>
          )}
        </div>
      </header>
      <article class="prose prose-gray max-w-none prose-headings:font-bold prose-a:text-primary-600 prose-a:no-underline hover:prose-a:underline prose-img:rounded-xl">
        <slot />
      </article>
    </div>
  </main>

  <section class="py-16 bg-primary-600">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-2xl font-bold text-white">Automatiza tus partes de viajeros</h2>
      <p class="mt-3 text-primary-100">15 días de prueba gratis. Sin tarjeta de crédito.</p>
      <a href={`${APP_URL}/register`} data-umami-event="cta-blog-footer-register" class="mt-6 inline-flex items-center px-6 py-3 text-base font-medium text-primary-600 bg-white hover:bg-primary-50 rounded-lg transition-colors">
        Crear cuenta gratis
      </a>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": title,
    "description": description,
    "datePublished": publishedIso,
    "dateModified": modifiedIso,
    "author": {
      "@type": "Organization",
      "name": author,
      "url": SITE_URL
    },
    "publisher": {
      "@type": "Organization",
      "name": "RegistroViajero",
      "url": SITE_URL,
      "logo": { "@type": "ImageObject", "url": `${SITE_URL}/logo.svg` }
    },
    "mainEntityOfPage": postUrl,
    "image": `${SITE_URL}/og-image.png`,
    "inLanguage": "es-ES"
  })} />

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <Footer />
</Layout>
