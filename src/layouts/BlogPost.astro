---
import Layout from './Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
import LocaleBanner from '../components/LocaleBanner.astro'
import { APP_URL, DEFAULT_LOCALE, LOCALE_META, LOCALES, SITE_URL, type Locale } from '../i18n/config'
import { absoluteUrl, buildLocalePaths, formatDate, localizedPath, type LocalePaths } from '../i18n/utils'
import { UI } from '../i18n/ui'
import { findTranslation, getSlug } from '../i18n/blog'

interface Props {
  title: string
  description: string
  date: Date
  updated?: Date
  author: string
  readingTime?: number
  slug: string
  locale: Locale
  translationKey: string
}

const { title, description, date, updated, author, readingTime, slug, locale, translationKey } = Astro.props

const t = UI[locale].blog

const otherLocale: Locale = locale === DEFAULT_LOCALE ? 'en' : DEFAULT_LOCALE
const translated = await findTranslation(translationKey, otherLocale)

const availableLocales: Locale[] = translated ? [...LOCALES] : [locale]

const logicalPath = `/blog/${slug}/`
const postUrl = absoluteUrl(locale, logicalPath)

// Build locale-specific URL paths so the slug used in hreflang alternates
// matches the actual translated post slug rather than reusing this locale's slug.
const localePaths: LocalePaths = buildLocalePaths(logicalPath, {
  [locale]: localizedPath(locale, logicalPath),
  ...(translated
    ? { [otherLocale]: localizedPath(otherLocale, `/blog/${getSlug(translated)}/`) }
    : {}),
})

const publishedIso = date.toISOString().split('T')[0]
const modifiedIso = (updated ?? date).toISOString().split('T')[0]

const formattedDate = formatDate(locale, date)
const formattedUpdated = updated ? formatDate(locale, updated) : null

const blogIndex = localizedPath(locale, '/blog')
const homePath = localizedPath(locale, '/')

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t.breadcrumbHome, item: absoluteUrl(locale, '/') },
    { '@type': 'ListItem', position: 2, name: t.breadcrumbBlog, item: absoluteUrl(locale, '/blog') },
    { '@type': 'ListItem', position: 3, name: title, item: postUrl },
  ],
}

---

<Layout
  title={`${title} — ${t.postTitleSuffix}`}
  description={description}
  type="article"
  publishedDate={publishedIso}
  modifiedDate={modifiedIso}
  locale={locale}
  logicalPath={logicalPath}
  localePaths={localePaths}
  availableLocales={availableLocales}
>
  <Nav locale={locale} localePaths={localePaths} />
  <LocaleBanner locale={locale} localePaths={localePaths} />

  <main class="pt-28 pb-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <nav aria-label="Breadcrumb" class="mb-6 text-sm">
        <ol class="flex flex-wrap items-center gap-2 text-gray-500">
          <li><a href={homePath} class="hover:text-primary-600">{t.breadcrumbHome}</a></li>
          <li aria-hidden="true">/</li>
          <li><a href={blogIndex} class="hover:text-primary-600">{t.breadcrumbBlog}</a></li>
          <li aria-hidden="true">/</li>
          <li class="text-gray-700 truncate max-w-[200px] sm:max-w-none">{title}</li>
        </ol>
      </nav>
      <a href={blogIndex} class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-primary-600 transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
        {t.backToBlog}
      </a>
      <header class="mb-10">
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 leading-tight">{title}</h1>
        <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-gray-500">
          <time datetime={publishedIso}>{formattedDate}</time>
          {updated && updated.valueOf() !== date.valueOf() && formattedUpdated && (
            <>
              <span aria-hidden="true">·</span>
              <span>{t.updated} <time datetime={modifiedIso}>{formattedUpdated}</time></span>
            </>
          )}
          <span aria-hidden="true">·</span>
          <span>{author}</span>
          {readingTime && (
            <>
              <span aria-hidden="true">·</span>
              <span>{t.readingTime(readingTime)}</span>
            </>
          )}
        </div>
      </header>
      <article class="prose prose-gray max-w-none prose-headings:font-bold prose-a:text-primary-600 prose-a:no-underline prose-a:hover:underline prose-img:rounded-xl">
        <slot />
      </article>
    </div>
  </main>

  <section class="py-16 bg-primary-600">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-2xl font-bold text-white">{t.ctaHeading}</h2>
      <p class="mt-3 text-primary-100">{t.ctaSubheading}</p>
      <a href={`${APP_URL}/register`} data-umami-event="cta-blog-footer-register" class="mt-6 inline-flex items-center px-6 py-3 text-base font-medium text-primary-600 bg-white hover:bg-primary-50 rounded-lg transition-colors">
        {t.ctaButton}
      </a>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": title,
    "description": description,
    "datePublished": publishedIso,
    "dateModified": modifiedIso,
    "author": {
      "@type": "Organization",
      "name": author,
      "url": SITE_URL
    },
    "publisher": {
      "@type": "Organization",
      "name": "RegistroViajero",
      "url": SITE_URL,
      "logo": { "@type": "ImageObject", "url": `${SITE_URL}/logo.svg` }
    },
    "mainEntityOfPage": postUrl,
    "image": `${SITE_URL}/og-image.png`,
    "inLanguage": LOCALE_META[locale].htmlLang
  })} />

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <Footer locale={locale} />
</Layout>
