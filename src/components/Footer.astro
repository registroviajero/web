---
import { APP_URL, HELP_URL, type Locale } from '../i18n/config'
import { getLocaleFromUrl, localizedPath } from '../i18n/utils'
import { UI, LEGAL_SLUGS } from '../i18n/ui'
import { LANDING } from '../i18n/content'

interface Props {
  locale?: Locale
}

const locale: Locale = Astro.props.locale ?? getLocaleFromUrl(Astro.url)
const t = UI[locale].footer
const sections = LANDING[locale].sections
const slugs = LEGAL_SLUGS[locale]

const year = new Date().getFullYear()

const legalPages = [
  { label: t.legalNotice, href: slugs.legalNotice },
  { label: t.privacy, href: slugs.privacy },
  { label: t.terms, href: slugs.terms },
  { label: t.cookies, href: slugs.cookies },
]

const home = localizedPath(locale, '/')
// home always ends in '/'. Strip it so we get '/#section' or '/en/#section'
// rather than '//#section'.
const homePrefix = home === '/' ? '' : home.replace(/\/$/, '')
const featuresHash = `${homePrefix}/#${sections.featuresId}`
const pricingHash = `${homePrefix}/#${sections.pricingId}`
const blogHref = localizedPath(locale, '/blog')
const rssHref = locale === 'es' ? '/rss.xml' : `/${locale}/rss.xml`
---

<footer class="bg-gray-900 py-12">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
      <div>
        <img src="/logo.svg" alt="RegistroViajero" class="h-8 brightness-0 invert opacity-80" width="40" height="40" />
        <p class="mt-4 text-sm text-gray-400 leading-relaxed">
          {t.tagline}
        </p>
      </div>
      <div>
        <h3 class="text-white font-semibold text-sm mb-4">{t.productHeading}</h3>
        <ul class="space-y-2 text-sm">
          <li><a href={featuresHash} class="text-gray-400 hover:text-white transition-colors duration-150">{UI[locale].nav.features}</a></li>
          <li><a href={pricingHash} class="text-gray-400 hover:text-white transition-colors duration-150">{UI[locale].nav.pricing}</a></li>
          <li><a href={blogHref} class="text-gray-400 hover:text-white transition-colors duration-150">{UI[locale].nav.blog}</a></li>
          <li>
            <a href={rssHref} class="inline-flex items-center gap-1.5 text-gray-400 hover:text-white transition-colors duration-150">
              <svg class="w-3.5 h-3.5 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
              </svg>
              {t.rss}
            </a>
          </li>
          <li><a href={HELP_URL} class="text-gray-400 hover:text-white transition-colors duration-150">{t.helpCenter}</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-white font-semibold text-sm mb-4">{t.legalHeading}</h3>
        <ul class="space-y-2 text-sm">
          {legalPages.map((p) => (
            <li><a href={p.href} class="text-gray-400 hover:text-white transition-colors duration-150">{p.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-white font-semibold text-sm mb-4">{t.accessHeading}</h3>
        <ul class="space-y-2 text-sm">
          <li><a href={`${APP_URL}/login`} class="text-gray-400 hover:text-white transition-colors duration-150">{t.login}</a></li>
          <li><a href={`${APP_URL}/register`} data-umami-event="cta-footer-register" class="text-gray-400 hover:text-white transition-colors duration-150">{t.createAccount}</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-12 pt-8 border-t border-gray-800 text-sm text-gray-400 text-center">
      {t.copyright(year)}
    </div>
  </div>
</footer>
