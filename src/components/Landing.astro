---
import { Image } from 'astro:assets'
import Nav from './Nav.astro'
import Footer from './Footer.astro'
import LocaleBanner from './LocaleBanner.astro'
import { APP_URL, HELP_URL, LOCALE_META, SITE_URL, type Locale } from '../i18n/config'
import { absoluteUrl, formatDate, localizedPath } from '../i18n/utils'
import { LANDING, type MockupKey } from '../i18n/content'
import { UI } from '../i18n/ui'
import { getPostsByLocale, getSlug } from '../i18n/blog'

// Mockups live in src/assets/ so Astro can format-negotiate (avif/webp)
// and emit responsive srcset at build time. New mockup → add a key to
// MockupKey in content.ts, an import here, and the entry in mockupMap.
import checkinImg from '../assets/mockups/checkin.webp'
import asistenteImg from '../assets/mockups/asistente.webp'
import auditImg from '../assets/mockups/audit.webp'
import reservasImg from '../assets/mockups/reservas.webp'
import alojamientoImg from '../assets/mockups/alojamiento.webp'
import dashboardImg from '../assets/mockups/dashboard.webp'

const mockupMap: Record<MockupKey, ImageMetadata> = {
  checkin: checkinImg,
  asistente: asistenteImg,
  audit: auditImg,
  reservas: reservasImg,
  alojamiento: alojamientoImg,
  dashboard: dashboardImg,
}

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const c = LANDING[locale]
const hero = c.hero
const s = c.sections
const meta = LOCALE_META[locale]

const latestPosts = (await getPostsByLocale(locale)).slice(0, 3)
const blogPath = localizedPath(locale, '/blog')

const softwareApplicationSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'RegistroViajero',
  url: SITE_URL,
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  description: c.schema.softwareDescription,
  inLanguage: meta.htmlLang,
  offers: [
    {
      '@type': 'Offer',
      name: c.schema.trialOfferName,
      price: '0',
      priceCurrency: 'EUR',
      description: c.schema.trialOfferDescription,
    },
    {
      '@type': 'Offer',
      name: c.schema.proOfferName,
      price: '5',
      priceCurrency: 'EUR',
      priceSpecification: {
        '@type': 'UnitPriceSpecification',
        price: '5',
        priceCurrency: 'EUR',
        unitText: c.schema.priceUnitText,
      },
      description: c.schema.priceDescription,
    },
  ],
  featureList: c.schema.featureList,
  publisher: {
    '@type': 'Organization',
    name: 'RegistroViajero',
    url: SITE_URL,
  },
}

const faqPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: c.faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.a,
    },
  })),
}

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: c.schema.howToName,
  description: c.schema.howToDescription,
  inLanguage: meta.htmlLang,
  totalTime: 'PT10M',
  step: c.steps.map((st, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: st.title,
    text: st.desc,
  })),
}
---

<Nav locale={locale} />
<LocaleBanner locale={locale} />

<main id="main-content">
<section class="pt-28 pb-20 sm:pt-36 sm:pb-24 overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-12 items-center">
      <div class="lg:col-span-7">
        <div data-animate class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary-50 text-primary-700 text-sm font-medium mb-6">
          {hero.pill}
        </div>
        <h1 data-animate style="--reveal-delay: 80ms" class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-gray-900 leading-[1.05]">
          {hero.title1} <span class="text-primary-600">{hero.titleAccent}</span>
        </h1>
        <p data-animate style="--reveal-delay: 160ms" class="mt-6 text-lg sm:text-xl text-gray-600 leading-relaxed max-w-2xl">
          {hero.subhead}
        </p>
        <div data-animate style="--reveal-delay: 240ms" class="mt-8 flex flex-col sm:flex-row gap-4">
          <a href={`${APP_URL}/register`} data-umami-event="cta-hero-register" class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-white bg-primary-600 hover:bg-primary-700 rounded-lg transition-all duration-200 shadow-sm hover:shadow-md hover:-translate-y-0.5">
            {hero.ctaPrimary}
          </a>
          <a href={`#${s.howItWorksId}`} data-umami-event="cta-hero-how" class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-gray-700 bg-white hover:bg-gray-50 border border-gray-300 rounded-lg transition-colors duration-200">
            {hero.ctaSecondary}
          </a>
        </div>
        <p data-animate style="--reveal-delay: 320ms" class="mt-4 text-sm text-gray-500">{hero.disclaimer}</p>
      </div>
      <div class="lg:col-span-5 hidden lg:flex justify-center" data-animate style="--reveal-delay: 200ms">
        <Image
          src={dashboardImg}
          alt={hero.phoneAlt}
          loading="eager"
          fetchpriority="high"
          widths={[280, 320, 640]}
          sizes="(min-width: 1024px) 320px, 0px"
          class="w-full max-w-[320px] animate-float drop-shadow-2xl"
        />
      </div>
    </div>
  </div>
</section>

<section class="py-16 sm:py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 space-y-24 sm:space-y-32">
    {c.spotlights.map((sp, i) => (
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-center">
        <div class={`lg:col-span-6 ${i % 2 === 0 ? 'lg:order-2' : ''}`}>
          <p data-animate class="text-xs font-semibold tracking-[0.18em] text-primary-600">{sp.eyebrow}</p>
          <h2 data-animate style="--reveal-delay: 80ms" class="mt-3 text-3xl sm:text-4xl font-bold text-gray-900 leading-tight">{sp.title}</h2>
          <p data-animate style="--reveal-delay: 160ms" class="mt-6 text-lg text-gray-600 leading-relaxed">{sp.body}</p>
          <ul class="mt-8 space-y-3">
            {sp.bullets.map((b, j) => (
              <li class="flex items-start gap-3" data-animate style={`--reveal-delay: ${240 + j * 80}ms`}>
                <svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-1" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                <span class="text-gray-700">{b}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class={`flex justify-center lg:col-span-6 ${i % 2 === 0 ? 'lg:order-1' : ''}`} data-animate style="--reveal-delay: 120ms">
          <Image
            src={mockupMap[sp.imageKey]}
            alt={sp.imageAlt}
            loading="lazy"
            widths={[300, 320, 640]}
            sizes="(min-width: 640px) 320px, 300px"
            class="w-full max-w-[300px] sm:max-w-[320px] drop-shadow-2xl"
          />
        </div>
      </div>
    ))}
  </div>
</section>

<section id={c.tour.id} class="py-20 bg-gray-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center max-w-2xl mx-auto mb-16" data-animate>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">{c.tour.title}</h2>
      <p class="mt-4 text-lg text-gray-600">{c.tour.intro}</p>
    </div>
    <div class="grid md:grid-cols-2 gap-12 lg:gap-16">
      {c.tour.cards.map((card, i) => (
        <div class="text-center" data-animate style={`--reveal-delay: ${i * 140}ms`}>
          <div class="flex justify-center mb-8">
            <Image src={mockupMap[card.imageKey]} alt={card.imageAlt} loading="lazy" widths={[240, 260, 520]} sizes="(min-width: 640px) 260px, 240px" class="w-full max-w-[240px] sm:max-w-[260px] drop-shadow-xl" />
          </div>
          <h3 class="text-xl font-bold text-gray-900">{card.title}</h3>
          <p class="mt-3 text-gray-600 leading-relaxed max-w-md mx-auto">{card.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section id={s.featuresId} class="py-20 bg-gray-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center max-w-2xl mx-auto mb-16" data-animate>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">{s.featuresTitle}</h2>
      <p class="mt-4 text-lg text-gray-600">{s.featuresIntro}</p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {c.features.map((f) => (
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 transition duration-200 hover:shadow-md hover:-translate-y-0.5" data-animate>
          <div class="w-10 h-10 rounded-lg bg-primary-50 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" set:html={f.icon} />
          </div>
          <h3 class="text-lg font-semibold text-gray-900">{f.title}</h3>
          <p class="mt-2 text-gray-600 leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section id={s.howItWorksId} class="py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center max-w-2xl mx-auto mb-16" data-animate>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">{s.howItWorksTitle}</h2>
      <p class="mt-4 text-lg text-gray-600">{s.howItWorksIntro}</p>
    </div>
    <div class="max-w-3xl mx-auto space-y-8">
      {c.steps.map((st) => (
        <div class="flex gap-6">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-primary-600 text-white flex items-center justify-center font-bold text-sm">
            {st.num}
          </div>
          <div>
            <h3 class="text-lg font-semibold text-gray-900">{st.title}</h3>
            <p class="mt-1 text-gray-600">{st.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="py-20 bg-gray-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">{s.platformsTitle}</h2>
    <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">{s.platformsIntro}</p>
    <div class="mt-12 flex flex-wrap items-center justify-center gap-x-10 gap-y-6 sm:gap-x-14">
      {c.platforms.map((p) => (
        <img
          src={`/platforms/${p.slug}.svg`}
          alt={p.name}
          width="120"
          height="32"
          loading="lazy"
          class="h-7 w-auto max-w-[120px] object-contain grayscale opacity-60 transition duration-200 hover:opacity-100 hover:grayscale-0"
        />
      ))}
    </div>
  </div>
</section>

<section id={s.segmentsId} class="py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center max-w-2xl mx-auto mb-16" data-animate>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">{s.segmentsTitle}</h2>
      <p class="mt-4 text-lg text-gray-600">{s.segmentsIntro}</p>
    </div>
    <div class="grid sm:grid-cols-2 gap-6">
      {c.segments.map((seg, i) => (
        <div class="group bg-white rounded-2xl p-8 border border-gray-100 shadow-sm hover:shadow-md hover:border-primary-200 transition-all duration-200" data-animate style={`--reveal-delay: ${i * 100}ms`}>
          <div class="w-12 h-12 rounded-xl bg-primary-50 flex items-center justify-center mb-5 group-hover:bg-primary-100 transition-colors duration-200">
            {i === 0 && <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M12.75 21h7.5V10.75M2.25 21h1.5m18 0h-18M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205l3 1m1.5.5l-1.5-.5M6.75 7.364V3h-3v18m3-13.636l10.5-3.819" /></svg>}
            {i === 1 && <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21" /></svg>}
            {i === 2 && <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>}
            {i === 3 && <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>}
          </div>
          <h3 class="text-lg font-semibold text-gray-900">{seg.title}</h3>
          <p class="mt-3 text-gray-600 leading-relaxed">{seg.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section id={s.pricingId} class="py-20 bg-gray-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center max-w-2xl mx-auto mb-16" data-animate>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">{s.pricingTitle}</h2>
      <p class="mt-4 text-lg text-gray-600">{s.pricingIntro}</p>
    </div>
    <div class="max-w-4xl mx-auto" data-animate>
      <div class="bg-white rounded-2xl shadow-lg border border-gray-200 overflow-hidden lg:grid lg:grid-cols-2 transition duration-300 hover:shadow-2xl">
        <!-- Price + CTA -->
        <div class="p-8 lg:p-10 bg-primary-600 flex flex-col justify-between">
          <div>
            <p class="text-sm font-semibold text-primary-200 tracking-wide uppercase">{s.pricingPlan}</p>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-5xl font-bold text-white">5&nbsp;€</span>
              <span class="text-primary-200 text-sm">{s.pricingPriceUnit}</span>
            </div>
            <p class="mt-2 text-sm text-primary-200">{s.pricingBillingNote}</p>
          </div>
          <div class="mt-8">
            <a href={`${APP_URL}/register`} data-umami-event="cta-pricing-register" class="block w-full text-center px-6 py-3 text-base font-medium text-primary-600 bg-white hover:bg-primary-50 rounded-lg transition-colors duration-150">
              {s.pricingCta}
            </a>
            <p class="mt-3 text-center text-sm text-primary-200">{s.pricingNoCard}</p>
            <div class="mt-8 pt-6 border-t border-primary-500">
              <p class="text-sm font-medium text-white">{s.pricingGuaranteeTitle}</p>
              <p class="mt-1 text-sm text-primary-200">{s.pricingGuaranteeBody}</p>
            </div>
          </div>
        </div>
        <!-- Features -->
        <div class="p-8 lg:p-10 flex items-center">
          <ul class="space-y-4 text-sm text-gray-700 w-full">
            {s.pricingFeatures.map((feat) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span>{feat}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
      <p class="mt-6 text-center text-sm text-gray-500 max-w-md mx-auto">
        {s.pricingSanctionsNote} <a href={s.pricingSanctionsHref} class="text-primary-600 underline">{s.pricingSanctionsLinkLabel}</a>.
      </p>
    </div>
  </div>
</section>

<section class="py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center max-w-2xl mx-auto mb-12" data-animate>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">{s.securityTitle}</h2>
      <p class="mt-4 text-lg text-gray-600">{s.securityIntro}</p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 text-center">
      {s.securityCards.map((card, i) => (
        <div class="bg-white rounded-xl p-6 border border-gray-100 transition duration-200 hover:shadow-md hover:-translate-y-0.5" data-animate>
          <div class="w-10 h-10 rounded-lg bg-primary-50 flex items-center justify-center mx-auto mb-3">
            {i === 0 && <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" /></svg>}
            {i === 1 && <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" /></svg>}
            {i === 2 && <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" /></svg>}
            {i === 3 && <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21" /></svg>}
          </div>
          <p class="font-semibold text-gray-900">{card.title}</p>
          <p class="mt-1 text-sm text-gray-600">{card.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section id={s.faqId} class="py-20 bg-gray-50">
  <div class="max-w-3xl mx-auto px-4 sm:px-6">
    <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 text-center mb-12">{s.faqTitle}</h2>
    <div class="space-y-4">
      {c.faqs.map((f) => (
        <details class="group bg-white border border-gray-200 rounded-xl">
          <summary class="flex items-center justify-between px-6 py-4 cursor-pointer text-gray-900 font-medium select-none">
            {f.q}
            <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform duration-200 flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </summary>
          {f.html
            ? <div class="px-6 pb-4 text-gray-600" set:html={f.html} />
            : <div class="px-6 pb-4 text-gray-600">{f.a}</div>
          }
        </details>
      ))}
    </div>
